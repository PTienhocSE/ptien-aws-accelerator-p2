# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and secrets. These should not be part of version control.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local development override
override.tf
override.tf.json
*_override.tf
*_override.tf.json
